# Clerk publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Backend API URL (e.g. https://your-api.onrender.com/api)
VITE_API_URL=http://localhost:5000/api

# EmailJS credentials — get these from https://www.emailjs.com/
# Restrict the public key to allowed domains in the EmailJS dashboard
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Admin route base path (optional, defaults to /admin)
# VITE_ADMIN_BASE=/admin
