# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio

# Clerk authentication
CLERK_SECRET_KEY=sk_live_...

# Admin email — must match the Clerk account that should have admin access
ADMIN_EMAIL=admin@example.com

# Cloudinary (image/PDF uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — set to your deployed frontend URL (e.g. https://yourportfolio.vercel.app)
ALLOWED_ORIGIN=http://localhost:5173

# Server port (optional, defaults to 5000)
PORT=5000
